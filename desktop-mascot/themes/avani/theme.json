{
  "$schema": "clawd-on-desk theme (codex-pet compatible) \u2014 importable into clawd-on-desk / codexpets and vice-versa",
  "id": "verity-avani",
  "name": "VERITY \u2014 AVANI (easter egg)",
  "author": "FUTRON / VERITY",
  "description": "Easter egg: AVANI herself, the Afrofuturistic neural companion. Head-and-shoulders profile reactions.",
  "palette": [
    "#2dd4bf",
    "#7c3aed",
    "#d6299e",
    "#070a0d"
  ],
  "eyeTracking": false,
  "capabilities": [
    "tracked-idle",
    "mini",
    "reactions",
    "sleep"
  ],
  "states": {
    "idle": {
      "asset": "../../assets/anim/avani-idle.webp",
      "format": "webp-anim",
      "loop": true
    },
    "thinking": {
      "asset": "../../assets/anim/avani-thinking.webp",
      "format": "webp-anim",
      "loop": true
    },
    "working": {
      "asset": "../../assets/anim/avani-building.webp",
      "format": "webp-anim",
      "loop": true
    },
    "juggling": {
      "asset": "../../assets/anim/avani-building.webp",
      "format": "webp-anim",
      "loop": true
    },
    "happy": {
      "asset": "../../assets/anim/avani-success.webp",
      "format": "webp-anim",
      "loop": true
    },
    "error": {
      "asset": "../../assets/anim/avani-error.webp",
      "format": "webp-anim",
      "loop": true
    },
    "notification": {
      "asset": "../../assets/anim/avani-notification.webp",
      "format": "webp-anim",
      "loop": true
    },
    "sleeping": {
      "asset": "../../assets/anim/avani-idle.webp",
      "format": "webp-anim",
      "loop": true
    }
  },
  "event_map": {
    "VERIFIED": "happy",
    "FOUND": "happy",
    "PASS": "happy",
    "click": "happy",
    "CORRECTED": "error",
    "NEGATIVE": "error",
    "DEFER": "error",
    "FAIL": "error",
    "search-before-concluding": "thinking",
    "NONE": "thinking",
    "swarm-plan": "juggling",
    "swarm-critic": "juggling",
    "swarm-synth": "juggling",
    "SubagentStart": "juggling",
    "assumption-caught": "notification",
    "PermissionRequest": "notification",
    "verify": "working",
    "preflight": "working",
    "PreToolUse": "working",
    "PostToolUse": "working",
    "proxy_down": "sleeping",
    "idle_60s": "sleeping"
  },
  "generation": {
    "method": "Generated NOT hand-drawn: clean transparent mascot PNG -> Ludo animateSprite (frame_size:-9, frames:16, model:blitz) -> download the RGBA SPRITESHEET (spritesheet_url, .webp) NOT the mp4 (no alpha) -> /tmp/sheet2webp.py splits the 4x4 grid into a transparent animated WebP. AVANI states come from pre-made transparent GIFs via /tmp/gif2webp.py. Verify corner alpha=0. See memory/feedback_transparent_animation_professional_motion.md.",
    "source_sprite": "AVANI Sprites/frames/avani-main (pre-made transparent GIFs)"
  }
}